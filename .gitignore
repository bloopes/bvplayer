node_modules/
dist/
dist-ssr/
*.local

# 包管理器日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# 2. 后端产物 (Rust / Tauri)
# ==========================================
src-tauri/target/

# ==========================================
# 3. 环境变量 (包含敏感信息)
# ==========================================
.env
.env.*
!.env.example

